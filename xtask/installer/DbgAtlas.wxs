<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="DbgAtlas"
    Manufacturer="DbgAtlas"
    Version="$(var.ProductVersion)"
    UpgradeCode="{B93AA16E-8D82-4A94-9D69-C781C6174501}"
    Scope="perMachine">
    <!--
      The package registers a machine-level Windows service, so service custom
      actions run elevated. INSTALLROOT defaults to a machine-wide Program
      Files path; managed installs may pass INSTALLROOT explicitly.
    -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of DbgAtlas is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLROOT" />
    <Property
      Id="WIXUI_EXITDIALOGOPTIONALTEXT"
      Value="DbgAtlas installation completed. Post-install diagnostics are available under the install root var\log directory." />
    <ui:WixUI Id="WixUI_InstallDir" />
    <WixVariable Id="WixUILicenseRtf" Value="$(sys.SOURCEFILEDIR)License.rtf" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLROOT" Name="DbgAtlas">
        <Directory Id="INSTALLBINDIR" Name="bin" />
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="DbgAtlas" Level="1">
      <ComponentRef Id="DbgAtlasPayload" />
    </Feature>

    <Component Id="DbgAtlasPayload" Directory="INSTALLBINDIR" Guid="{A72D2958-F040-4C01-8012-D20DB9051FF5}" Bitness="always64">
      <File Id="DbgatlasExe" Source="$(var.ReleaseDir)\dbgatlas.exe" KeyPath="yes" />
      <File Source="$(var.ReleaseDir)\dbgatlas-worker.exe" />
      <File Source="$(var.ReleaseDir)\dbgatlas_dbgeng.dll" />
      <File Source="$(var.ReleaseDir)\dbgatlas_etw.dll" />
      <File Source="$(var.ReleaseDir)\dbgatlas_ida.dll" />
    </Component>

    <!-- MSI directory properties end with '\'; appending '.' keeps the closing quote from being escaped. -->
    <CustomAction
      Id="InstallDbgAtlasService"
      FileRef="DbgatlasExe"
      ExeCommand="service install --install-root &quot;[INSTALLROOT].&quot; --payload-mode use-existing --force --bind 127.0.0.1:7331"
      Execute="deferred"
      Impersonate="no"
      Return="check" />
    <CustomAction
      Id="StartDbgAtlasService"
      FileRef="DbgatlasExe"
      ExeCommand="service start --install-root &quot;[INSTALLROOT].&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="check" />
    <CustomAction
      Id="RunDbgAtlasDoctor"
      FileRef="DbgatlasExe"
      ExeCommand="service doctor --install-root &quot;[INSTALLROOT].&quot; --report-path &quot;[INSTALLROOT]var\log\postinstall-report.txt&quot; --msi-summary-path &quot;[INSTALLROOT]var\log\postinstall-summary.txt&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="check" />
    <Binary Id="ReadDoctorSummaryScript" SourceFile="$(sys.SOURCEFILEDIR)ReadDoctorSummary.vbs" />
    <CustomAction
      Id="ReadDbgAtlasDoctorSummary"
      BinaryRef="ReadDoctorSummaryScript"
      VBScriptCall="ReadDbgAtlasDoctorSummary"
      Execute="immediate"
      Return="ignore" />
    <CustomAction
      Id="StopDbgAtlasService"
      FileRef="DbgatlasExe"
      ExeCommand="service stop --install-root &quot;[INSTALLROOT].&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />
    <CustomAction
      Id="UninstallDbgAtlasService"
      FileRef="DbgatlasExe"
      ExeCommand="service uninstall --install-root &quot;[INSTALLROOT].&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="InstallDbgAtlasService" After="InstallFiles" Condition="NOT Installed" />
      <Custom Action="StartDbgAtlasService" After="InstallDbgAtlasService" Condition="NOT Installed" />
      <Custom Action="RunDbgAtlasDoctor" After="StartDbgAtlasService" Condition="NOT Installed" />
      <Custom Action="StopDbgAtlasService" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="UninstallDbgAtlasService" After="StopDbgAtlasService" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>
    <InstallUISequence>
      <Custom Action="ReadDbgAtlasDoctorSummary" After="ExecuteAction" Condition="NOT Installed" />
    </InstallUISequence>
  </Package>
</Wix>
