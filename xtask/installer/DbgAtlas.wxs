<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="DbgAtlas"
    Manufacturer="DbgAtlas"
    Version="$(var.ProductVersion)"
    UpgradeCode="{B93AA16E-8D82-4A94-9D69-C781C6174501}"
    Scope="perMachine">
    <!--
      The package registers a machine-level Windows service, so service custom
      actions run elevated. INSTALLROOT must resolve to the intended user's
      Local Programs path; managed installs should pass INSTALLROOT explicitly.
    -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of DbgAtlas is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLROOT" Name="dbgatlas">
          <Directory Id="INSTALLBINDIR" Name="bin" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="DbgAtlas" Level="1">
      <ComponentRef Id="DbgAtlasPayload" />
    </Feature>

    <Component Id="DbgAtlasPayload" Directory="INSTALLBINDIR" Guid="{A72D2958-F040-4C01-8012-D20DB9051FF5}">
      <File Id="DbgatlasExe" Source="$(var.ReleaseDir)\dbgatlas.exe" KeyPath="yes" />
      <File Source="$(var.ReleaseDir)\dbgatlas-worker.exe" />
      <File Source="$(var.ReleaseDir)\dbgatlas_dbgeng.dll" />
      <File Source="$(var.ReleaseDir)\dbgatlas_etw.dll" />
      <File Source="$(var.ReleaseDir)\dbgatlas_ida.dll" />
      <File Source="$(var.ReleaseDir)\libgcc_s_seh-1.dll" />
      <File Source="$(var.ReleaseDir)\libstdc++-6.dll" />
      <File Source="$(var.ReleaseDir)\libwinpthread-1.dll" />
    </Component>

    <CustomAction
      Id="InstallDbgAtlasService"
      FileRef="DbgatlasExe"
      ExeCommand="service install --install-root &quot;[INSTALLROOT]&quot; --payload-mode use-existing --force --bind 127.0.0.1:7331"
      Execute="deferred"
      Impersonate="no"
      Return="check" />
    <CustomAction
      Id="StartDbgAtlasService"
      FileRef="DbgatlasExe"
      ExeCommand="service start --install-root &quot;[INSTALLROOT]&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="check" />
    <CustomAction
      Id="StopDbgAtlasService"
      FileRef="DbgatlasExe"
      ExeCommand="service stop --install-root &quot;[INSTALLROOT]&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />
    <CustomAction
      Id="UninstallDbgAtlasService"
      FileRef="DbgatlasExe"
      ExeCommand="service uninstall --install-root &quot;[INSTALLROOT]&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="InstallDbgAtlasService" After="InstallFiles" Condition="NOT Installed" />
      <Custom Action="StartDbgAtlasService" After="InstallDbgAtlasService" Condition="NOT Installed" />
      <Custom Action="StopDbgAtlasService" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="UninstallDbgAtlasService" After="StopDbgAtlasService" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>
  </Package>
</Wix>
